      "src": "camera_a/DSC0001.jpg",
      "scenario": "camera_a DSC0001.jpg - first, no rename",
      "expected_status": "imported",
      "expected_dest_contains": [
        "2024",
        "05-03",
        "Sony A7IV"
      ],
      "expected_crc32c_nonnull": true,
      "expected_db_row": true,
      "check_original_name": "DSC0001.jpg"
    },
    {
      "id": "s8_camera_b_conflict",
      "src": "camera_b/DSC0001.jpg",
      "scenario": "camera_b DSC0001.jpg - conflict #1, should be renamed",
      "expected_status": "imported",
      "expected_dest_contains": [
        "2024",
        "05-03",
        "Sony A7IV"
      ],
      "expected_dest_not_contains": [
        "camera_b"
      ],
      "expected_crc32c_nonnull": true,
      "expected_db_row": true,
      "check_renamed_from": "DSC0001.jpg"
    },
    {
