      "expected_status": "duplicate",
      "expected_dup_reason": [
        "db",
        "batch"
      ],
      "expected_db_row": false,
      "note": "Must be imported AFTER apple_with_exif.jpg to trigger DB dedup"
    },
    {
      "id": "s4_duplicate_4",
      "src": "z_dup_apple_5.jpg",
      "scenario": "exact duplicate #5 of apple_with_exif.jpg",
      "expected_status": "duplicate",
      "expected_dup_reason": [
        "db",
        "batch"
      ],
      "expected_db_row": false,
      "note": "Must be imported AFTER apple_with_exif.jpg to trigger DB dedup"
    },
    {
      "id": "s4_duplicate_5",
